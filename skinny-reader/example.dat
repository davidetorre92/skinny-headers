# example.dat — demonstrates all supported value types

# integers
count       42
offset      -7

# floats and doubles
ratio       0.5f
pi          3.14159

# strings
greeting    "hello world"
note        "look mom! I'm a string!"

# lists
scores      [10, 20, 30, 40]
weights     [0.5f, 1.2f, 3.0f]
values      [1.0, 2.0, 3.14]
names       ["alice", "bob", "carol"]
